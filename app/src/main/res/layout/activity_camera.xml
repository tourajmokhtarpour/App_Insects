<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- پیش‌نمایش دوربین -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLocation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ✅ لایه Overlay برای Bounding Box بلادرنگ -->
    <com.example.insectdetector.view.InsectOverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView" />

    <!-- ✅ کارت اطلاعات تشخیص بلادرنگ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDetectionInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#CC000000"
        android:visibility="gone"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvDetectedClass"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="در حال تشخیص..."
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDetectedConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اطمینان: --٪"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="4dp"
                android:layout_marginStart="28dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ✅ نشانگر وضعیت تشخیص -->
    <ImageView
        android:id="@+id/ivDetectionIndicator"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@android:drawable/presence_invisible"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView" />

    <!-- موقعیت GPS -->
    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="📍 در حال دریافت موقعیت..."
        android:textSize="12sp"
        android:textColor="@color/white"
        android:background="#80000000"
        android:padding="8dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- کنترل‌های پایین -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- دکمه انصراف -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="✕"
            android:textSize="20sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="30dp"
            app:strokeColor="@color/white"
            android:layout_marginEnd="30dp" />

        <!-- ✅ دکمه OK (جایگزین Capture) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="✓"
            android:textSize="36sp"
            android:textStyle="bold"
            app:cornerRadius="40dp"
            android:enabled="false" />

        <!-- ✅ دکمه راهنما -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInfo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="ℹ"
            android:textSize="20sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="30dp"
            app:strokeColor="@color/white"
            android:layout_marginStart="30dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
